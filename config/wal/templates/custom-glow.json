{{
  "document": {{
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "{color7}",
    "margin": 2
  }},
  "block_quote": {{
    "indent": 1,
    "indent_token": "│ "
  }},
  "paragraph": {{}},
  "list": {{
    "level_indent": 2
  }},
  "heading": {{
    "block_suffix": "\n",
    "color": "{color6}",
    "bold": true
  }},
  "h1": {{
    "prefix": "# "
  }},
  "h2": {{
    "prefix": "## "
  }},
  "h3": {{
    "prefix": "### "
  }},
  "h4": {{
    "prefix": "#### "
  }},
  "h5": {{
    "prefix": "##### "
  }},
  "h6": {{
    "prefix": "###### "
  }},
  "text": {{}},
  "strikethrough": {{
    "crossed_out": true
  }},
  "emph": {{
    "italic": true
  }},
  "strong": {{
    "bold": true
  }},
  "hr": {{
    "color": "{color8}",
    "format": "\n--------\n"
  }},
  "item": {{
    "block_prefix": "• "
  }},
  "enumeration": {{
    "block_prefix": ". "
  }},
  "task": {{
    "ticked": "[✓] ",
    "unticked": "[ ] "
  }},
  "link": {{
    "color": "{color2}",
    "underline": true
  }},
  "link_text": {{
    "color": "{color5}",
    "bold": true
  }},
  "image": {{
    "color": "{color8}",
    "underline": true
  }},
  "image_text": {{
    "color": "{color8}"
  }},
  "table": {{
    "color": "{color7}"
  }},
  "definition_list": {{}},
  "definition_term": {{}},
  "definition_description": {{
    "block_prefix": "\n🠶 "
  }},
  "html_block": {{}},
  "html_span": {{}}
}}
